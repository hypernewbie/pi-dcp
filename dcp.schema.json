{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hypernewbie/pi-dcp/raw/main/dcp.schema.json",
  "title": "pi-dcp configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": { "type": "boolean", "default": true },
    "debug": { "type": "boolean", "default": false },
    "notification": { "enum": ["off", "minimal", "detailed"], "default": "detailed" },
    "pruning": { "$ref": "#/$defs/pruning" },
    "triggers": { "$ref": "#/$defs/triggers" },
    "compaction": { "$ref": "#/$defs/compaction" },
    "contextRelief": { "$ref": "#/$defs/contextRelief" },
    "protectedTools": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "protectedFilePatterns": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean", "default": true } }
    }
  },
  "$defs": {
    "pruning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "turnProtection": { "$ref": "#/$defs/turnProtection" },
        "deduplication": { "$ref": "#/$defs/deduplication" },
        "purgeErrors": { "$ref": "#/$defs/purgeErrors" }
      }
    },
    "turnProtection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "turns": { "type": "integer", "minimum": 0, "default": 4 }
      }
    },
    "deduplication": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "protectedTools": { "type": ["array", "null"], "items": { "type": "string" } }
      }
    },
    "purgeErrors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "turns": { "type": "integer", "minimum": 1, "default": 4 },
        "protectedTools": { "type": ["array", "null"], "items": { "type": "string" } }
      }
    },
    "triggers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endOfTurn": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "tokenThresholdPercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100, "default": 73 },
            "tokenThresholdAbsolute": { "type": ["number", "null"], "minimum": 0, "default": 450000 },
            "cooldownTurns": { "type": "integer", "minimum": 0, "default": 2 },
            "focus": { "type": "string" },
            "autoContinue": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "contextRelief": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "triggerPercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100, "default": null },
        "targetHeadroomTokens": { "type": "integer", "minimum": 0, "default": 60000 },
        "maxChunkInputTokens": { "type": "integer", "minimum": 1, "default": 60000 },
        "maxChunkSummaryTokens": { "type": "integer", "minimum": 1, "default": 25000 },
        "exactEvidenceTokens": { "type": "integer", "minimum": 0, "default": 8000 },
        "preservedUserMessageTokens": { "type": "integer", "minimum": 1000, "default": 2000 },
        "activeWorkingSetTokens": { "type": "integer", "minimum": 0, "default": 35000 }
      }
    },
    "compaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "customSummary": { "type": "boolean", "default": true },
        "summaryModel": { "type": ["string", "null"] },
        "maxSummaryTokens": { "type": "integer", "minimum": 1, "default": 20000 },
        "protectedTools": { "type": ["array", "null"], "items": { "type": "string" } },
        "protectedFilePatterns": { "type": ["array", "null"], "items": { "type": "string" } },
        "protectUserMessages": { "type": "boolean", "default": false },
        "maxProtectedTokens": { "type": "integer", "minimum": 1000, "default": 24000 },
        "preservedUserMessageTokens": { "type": "integer", "minimum": 1000, "default": 2000 },
        "preserveSubagentResults": { "type": "boolean", "default": true },
        "showCompression": { "type": "boolean", "default": false }
      }
    }
  }
}
